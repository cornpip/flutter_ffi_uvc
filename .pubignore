# README images are resolved from the repository URL by pub.dev, so they do
# not need to ship in the package archive.
readme_img/

# Maintainer/design documentation lives in the repository; it is not needed
# inside the package archive.
doc/

# Mirror of .gitignore — a .pubignore replaces (not merges with) .gitignore
# for pub, so anything git ignores must be repeated here.
